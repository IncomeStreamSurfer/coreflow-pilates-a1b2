---
import Base from '../layouts/Base.astro';
import { anonClient } from '../lib/supabase';

const title = "Pilates Class Schedule | Core & Flow Studio";
const description = "View our full weekly pilates class schedule in Austin and book your spot instantly online.";
const SITE = import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app';

const sb = anonClient();
let sessions: any[] = [];
if (sb) {
  const now = new Date().toISOString();
  const twoWeeks = new Date(Date.now() + 14 * 24 * 60 * 60 * 1000).toISOString();
  const { data } = await sb
    .from('class_sessions')
    .select('id, start_time, end_time, capacity, spots_booked, location, classes(name, slug, class_type), instructors(name, slug)')
    .gte('start_time', now)
    .lte('start_time', twoWeeks)
    .order('start_time');
  sessions = data ?? [];
}

// group by calendar date, precomputing display fields to keep the markup simple
const groups = new Map<string, any[]>();
for (const s of sessions) {
  const d = new Date(s.start_time);
  const key = d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', timeZone: 'America/Chicago' });
  const spotsLeft = s.capacity - s.spots_booked;
  const full = spotsLeft <= 0;
  const availabilityLabel = full ? 'Full' : spotsLeft + (spotsLeft === 1 ? ' spot left' : ' spots left');
  const row = { ...s, spotsLeft, full, availabilityLabel };
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(row);
}

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: sessions.slice(0, 20).map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${s.classes?.name} with ${s.instructors?.name}`,
  })),
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'Schedule', item: SITE + '/schedule' },
  ],
};

function timeStr(iso: string) {
  return new Date(iso).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZone: 'America/Chicago' });
}
---

<Base title={title} description={description} structuredData={[itemListSchema, breadcrumb]}>
  <section class="mx-auto max-w-4xl px-6 py-16 md:py-24">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-clay">Live schedule</p>
    <h1 class="mt-3 font-display text-4xl tracking-tight text-ink md:text-5xl">Weekly class schedule</h1>
    <p class="mt-5 max-w-2xl leading-relaxed text-ink-muted">
      Every upcoming class at our South Congress studio, updated in real time. Tap any class to reserve your spot — availability shown reflects live bookings. Curious what each format involves? Browse our <a href="/classes" class="text-clay underline underline-offset-4">pilates class types</a> first.
    </p>
  </section>

  <section class="border-t border-line">
    <div class="mx-auto max-w-4xl px-6 py-12 md:py-16">
      {groups.size === 0 && (
        <p class="text-ink-muted">Schedule is updating — check back shortly, or <a href="/book" class="text-clay underline">go straight to booking</a>.</p>
      )}
      <div class="space-y-10">
        {Array.from(groups.entries()).map(([day, list]) => (
          <div>
            <h2 class="font-display text-xl text-ink">{day}</h2>
            <div class="mt-4 divide-y divide-line rounded-lg border border-line bg-white/40">
              {list.map((s) => {
                const bookHref = s.full ? '#' : '/book?session=' + s.id;
                const pillClass = s.full
                  ? 'rounded-full px-4 py-2 text-xs font-medium transition pointer-events-none bg-line text-ink-muted'
                  : 'rounded-full px-4 py-2 text-xs font-medium transition bg-ink text-paper hover:bg-clay';
                const availClass = s.full ? 'text-xs text-ink-muted' : 'text-xs text-clay';
                return (
                  <div class="flex flex-wrap items-center justify-between gap-3 px-5 py-4">
                    <div>
                      <p class="font-medium text-ink">{s.classes?.name}</p>
                      <p class="text-sm text-ink-muted">{timeStr(s.start_time)} – {timeStr(s.end_time)} · {s.instructors?.name} · {s.location}</p>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class={availClass}>{s.availabilityLabel}</span>
                      <a href={bookHref} aria-disabled={s.full} class={pillClass}>
                        {s.full ? 'Full' : 'Reserve'}
                      </a>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-line bg-ink">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-6 py-16 md:flex-row md:items-center md:justify-between">
      <h2 class="font-display text-2xl text-paper md:text-3xl">Don't see a time that works?</h2>
      <a href="/instructors" class="shrink-0 rounded-full bg-clay px-7 py-3.5 text-sm font-medium text-paper transition hover:bg-clay-dark">Meet our instructors</a>
    </div>
  </section>
</Base>
