---
import Base from '../layouts/Base.astro';
import { anonClient } from '../lib/supabase';

const title = "Book a Pilates Class | Core & Flow Studio Austin";
const description = "Reserve your spot in a mat, reformer, prenatal, barre, or private pilates class at Core & Flow Studio in Austin. Secure online payment.";
const SITE = import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app';

const preselect = Astro.url.searchParams.get('session') ?? '';

const sb = anonClient();
let sessions: any[] = [];
if (sb) {
  const { data } = await sb
    .from('class_sessions')
    .select('id, start_time, end_time, capacity, spots_booked, location, classes(name, slug, price_cents, currency), instructors(name)')
    .gte('start_time', new Date().toISOString())
    .order('start_time')
    .limit(60);
  sessions = (data ?? []).filter((s: any) => s.capacity - s.spots_booked > 0);
}

function label(s: any) {
  const d = new Date(s.start_time);
  const when = d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', timeZone: 'America/Chicago' }) +
    ' · ' + d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZone: 'America/Chicago' });
  const spotsLeft = s.capacity - s.spots_booked;
  return `${s.classes?.name} — ${when} with ${s.instructors?.name} (${spotsLeft} left)`;
}

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'Book a class', item: SITE + '/book' },
  ],
};
---

<Base title={title} description={description} structuredData={breadcrumb}>
  <section class="mx-auto max-w-2xl px-6 py-16 md:py-24">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-clay">Book online</p>
    <h1 class="mt-3 font-display text-4xl tracking-tight text-ink md:text-5xl">Reserve your spot</h1>
    <p class="mt-5 leading-relaxed text-ink-muted">
      Choose a class from the list below, add your details, and pay securely with Stripe. Your spot is confirmed the moment payment goes through — no waiting on a callback. See the <a href="/schedule" class="text-clay underline underline-offset-4">full weekly schedule</a> for everything on offer.
    </p>

    <form id="booking-form" class="mt-10 space-y-5 rounded-lg border border-line bg-white/40 p-6">
      <div>
        <label for="session" class="text-sm font-medium text-ink">Class</label>
        <select id="session" name="session_id" required class="mt-1 w-full rounded-md border border-line bg-paper px-4 py-2.5 text-sm outline-none focus:border-clay">
          <option value="" disabled selected={!preselect}>Select a class time…</option>
          {sessions.map((s) => (
            <option value={s.id} selected={s.id === preselect}>{label(s)}</option>
          ))}
        </select>
        {sessions.length === 0 && <p class="mt-2 text-xs text-ink-muted">No open sessions loaded — try refreshing, or view the <a href="/schedule" class="text-clay underline">schedule</a>.</p>}
      </div>

      <div>
        <label for="spots" class="text-sm font-medium text-ink">Number of spots</label>
        <select id="spots" name="spots" class="mt-1 w-full rounded-md border border-line bg-paper px-4 py-2.5 text-sm outline-none focus:border-clay">
          <option value="1" selected>1</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4">4</option>
        </select>
      </div>

      <div>
        <label for="name" class="text-sm font-medium text-ink">Full name</label>
        <input id="name" name="customer_name" type="text" required class="mt-1 w-full rounded-md border border-line bg-paper px-4 py-2.5 text-sm outline-none focus:border-clay" />
      </div>
      <div>
        <label for="email" class="text-sm font-medium text-ink">Email</label>
        <input id="email" name="customer_email" type="email" required class="mt-1 w-full rounded-md border border-line bg-paper px-4 py-2.5 text-sm outline-none focus:border-clay" />
      </div>
      <div>
        <label for="phone" class="text-sm font-medium text-ink">Phone (optional)</label>
        <input id="phone" name="customer_phone" type="tel" class="mt-1 w-full rounded-md border border-line bg-paper px-4 py-2.5 text-sm outline-none focus:border-clay" />
      </div>

      <input type="text" name="website" aria-hidden="true" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0" />

      <button type="submit" id="book-submit" class="w-full rounded-full bg-clay px-6 py-3.5 text-sm font-medium text-paper transition hover:bg-clay-dark">
        Continue to payment
      </button>
      <p id="book-status" class="text-sm text-ink-muted" role="status"></p>
    </form>

    <p class="mt-6 text-xs text-ink-muted">
      Payments are processed securely by Stripe. Cancel or reschedule up to 12 hours before class for a full refund — see our <a href="/faq" class="text-clay underline underline-offset-4">FAQ</a> for details.
    </p>
  </section>
</Base>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement | null;
  const status = document.getElementById('book-status');
  const submitBtn = document.getElementById('book-submit') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form).entries());
    if (!data.session_id) {
      if (status) status.textContent = 'Please select a class.';
      return;
    }
    if (submitBtn) submitBtn.disabled = true;
    if (status) status.textContent = 'Redirecting to secure payment…';
    try {
      const res = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (res.ok && json.url) {
        window.location.href = json.url;
      } else {
        if (status) status.textContent = json.error || 'Something went wrong — please try again.';
        if (submitBtn) submitBtn.disabled = false;
      }
    } catch {
      if (status) status.textContent = 'Network error — please try again.';
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
