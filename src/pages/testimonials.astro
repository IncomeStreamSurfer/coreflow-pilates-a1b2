---
import Base from '../layouts/Base.astro';
import { anonClient } from '../lib/supabase';

const title = "Member Testimonials | Core & Flow Studio";
const description = "Read what Core & Flow Pilates Studio members in Austin say about mat, reformer, and prenatal classes.";
const SITE = import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app';

const sb = anonClient();
let testimonials: any[] = [];
if (sb) {
  const { data } = await sb
    .from('testimonials')
    .select('author_name, author_title, quote, rating, featured')
    .order('sort_order');
  testimonials = data ?? [];
}

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'Testimonials', item: SITE + '/testimonials' },
  ],
};

const featured = testimonials.find((t) => t.featured) ?? testimonials[0];
const rest = testimonials.filter((t) => t !== featured);
---

<Base title={title} description={description} structuredData={breadcrumb}>
  <section class="mx-auto max-w-4xl px-6 py-16 md:py-24">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-clay">Testimonials</p>
    <h1 class="mt-3 font-display text-4xl tracking-tight text-ink md:text-5xl">What members say</h1>
  </section>

  {featured && (
    <section class="border-t border-line bg-white/40">
      <div class="mx-auto max-w-3xl px-6 py-16 text-center md:py-20">
        <p class="font-display text-2xl leading-snug text-ink md:text-3xl">&ldquo;{featured.quote}&rdquo;</p>
        <p class="mt-6 text-sm text-ink-muted">{featured.author_name} · {featured.author_title}</p>
      </div>
    </section>
  )}

  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
      <div class="grid gap-6 md:grid-cols-3">
        {rest.map((t) => (
          <div class="rounded-lg border border-line bg-white/40 p-6">
            <p class="text-sm leading-relaxed text-ink">&ldquo;{t.quote}&rdquo;</p>
            <p class="mt-4 text-xs uppercase tracking-wide text-ink-muted">{t.author_name} · {t.author_title}</p>
          </div>
        ))}
      </div>
      {testimonials.length === 0 && <p class="text-ink-muted">Testimonials are loading — check back shortly.</p>}
    </div>
  </section>

  <section class="border-t border-line bg-ink">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-6 py-16 md:flex-row md:items-center md:justify-between">
      <h2 class="font-display text-2xl text-paper md:text-3xl">See what the fuss is about.</h2>
      <a href="/book" class="shrink-0 rounded-full bg-clay px-7 py-3.5 text-sm font-medium text-paper transition hover:bg-clay-dark">Book a class</a>
    </div>
  </section>
</Base>
