---
import Base from '../layouts/Base.astro';
import { anonClient } from '../lib/supabase';
import { safeHtml } from '../lib/sanitize';

const SITE = import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app';
const sb = anonClient();
let page: any = null;
if (sb) {
  const { data } = await sb
    .from('pages')
    .select('title, meta_title, meta_description, body_html, schema_data')
    .eq('slug', 'about')
    .not('published_at', 'is', null)
    .maybeSingle();
  page = data;
}

const title = page?.meta_title || 'About Us | Core & Flow Pilates Studio Austin';
const description = page?.meta_description || 'Learn the story behind Core & Flow Pilates Studio in Austin.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'About', item: SITE + '/about' },
  ],
};
---

<Base title={title} description={description} structuredData={breadcrumb}>
  <article class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-clay">Our story</p>
    <h1 class="mt-3 font-display text-4xl tracking-tight text-ink md:text-5xl">{page?.title || 'About Core & Flow'}</h1>
    <div class="prose prose-lg mt-8 max-w-none leading-relaxed text-ink">
      {page?.body_html ? (
        <div set:html={safeHtml(page.body_html)} />
      ) : (
        <p>Core & Flow opened on South Congress in Austin with one rule: keep classes small.</p>
      )}
    </div>
    <p class="mt-10 text-sm text-ink-muted">
      Meet the instructors behind every class on our <a href="/instructors" class="text-clay underline underline-offset-4">instructor bios page</a>, or view <a href="/schedule" class="text-clay underline underline-offset-4">this week's schedule</a> to book your first visit.
    </p>
  </article>
</Base>
