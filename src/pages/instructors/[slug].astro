---
import Base from '../../layouts/Base.astro';
import { anonClient } from '../../lib/supabase';

export const prerender = false;

const { slug } = Astro.params;
const SITE = import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app';

const sb = anonClient();
let instructor: any = null;
let sessions: any[] = [];
if (sb) {
  const { data } = await sb
    .from('instructors')
    .select('*')
    .eq('slug', slug)
    .not('published_at', 'is', null)
    .maybeSingle();
  instructor = data;

  if (instructor) {
    const { data: sess } = await sb
      .from('class_sessions')
      .select('id, start_time, classes(name, slug)')
      .eq('instructor_id', instructor.id)
      .gte('start_time', new Date().toISOString())
      .order('start_time')
      .limit(4);
    sessions = sess ?? [];
  }
}

if (!instructor) {
  return new Response('Not found', { status: 404 });
}

const title = `${instructor.name} | Pilates Instructor | Core & Flow Studio`;
const description = `Meet ${instructor.name}, ${instructor.role} at Core & Flow Pilates Studio in Austin. ${(instructor.bio || '').slice(0, 100)}`;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: instructor.name,
  jobTitle: instructor.role,
  worksFor: { '@type': 'LocalBusiness', name: 'Core & Flow Pilates Studio' },
  image: instructor.image_url,
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'Instructors', item: SITE + '/instructors' },
    { '@type': 'ListItem', position: 3, name: instructor.name, item: SITE + '/instructors/' + instructor.slug },
  ],
};

function timeStr(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', timeZone: 'America/Chicago' }) +
    ' · ' + d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZone: 'America/Chicago' });
}
---

<Base title={title} description={description} ogImage={instructor.image_url} structuredData={[personSchema, breadcrumb]}>
  <article class="mx-auto max-w-4xl px-6 py-16 md:py-24">
    <div class="grid gap-10 md:grid-cols-[280px_1fr]">
      <div>
        <div class="aspect-[4/5] overflow-hidden rounded-lg border border-line">
          <img src={instructor.image_url} alt={`${instructor.name}, ${instructor.role}`} class="h-full w-full object-cover" />
        </div>
        <div class="mt-6">
          <p class="text-xs font-medium uppercase tracking-wide text-ink-muted">Certifications</p>
          <ul class="mt-2 space-y-1 text-sm text-ink-muted">
            {(instructor.certifications || []).map((c: string) => <li>{c}</li>)}
          </ul>
        </div>
      </div>
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-clay">Instructor</p>
        <h1 class="mt-3 font-display text-4xl tracking-tight text-ink">{instructor.name}</h1>
        <p class="mt-1 text-ink-muted">{instructor.role}</p>
        <p class="mt-6 leading-relaxed text-ink">{instructor.bio}</p>

        {sessions.length > 0 && (
          <div class="mt-8">
            <p class="text-xs font-medium uppercase tracking-wide text-ink-muted">Upcoming classes</p>
            <div class="mt-3 divide-y divide-line rounded-lg border border-line bg-white/40">
              {sessions.map((s) => (
                <a href={`/book?session=${s.id}`} class="flex items-center justify-between px-5 py-3 text-sm transition hover:bg-white">
                  <span class="text-ink">{s.classes?.name}</span>
                  <span class="text-ink-muted">{timeStr(s.start_time)}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/book" class="rounded-full bg-clay px-6 py-3 text-sm font-medium text-paper transition hover:bg-clay-dark">Book a class</a>
          <a href="/instructors" class="text-sm font-medium text-ink underline decoration-line underline-offset-4 hover:text-clay">All instructors</a>
        </div>
      </div>
    </div>
  </article>
</Base>
