---
import Base from '../../layouts/Base.astro';
import { anonClient } from '../../lib/supabase';

const title = "Meet Our Pilates Instructors | Core & Flow Studio";
const description = "Meet the certified pilates instructors at Core & Flow Studio in Austin — mat, reformer, prenatal, barre, and private session specialists.";
const SITE = import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app';

const sb = anonClient();
let instructors: any[] = [];
if (sb) {
  const { data } = await sb
    .from('instructors')
    .select('slug, name, role, bio, image_url, specialties')
    .not('published_at', 'is', null)
    .order('sort_order');
  instructors = data ?? [];
}

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'Instructors', item: SITE + '/instructors' },
  ],
};
---

<Base title={title} description={description} structuredData={breadcrumb}>
  <section class="mx-auto max-w-6xl px-6 py-16 md:py-24">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-clay">Our team</p>
    <h1 class="mt-3 font-display text-4xl tracking-tight text-ink md:text-5xl">Meet our instructors</h1>
    <p class="mt-5 max-w-2xl leading-relaxed text-ink-muted">
      Every instructor at Core &amp; Flow holds a comprehensive certification (500+ training hours, not a weekend course), and each brings a specialty — reformer, prenatal care, rehab — to the studio. See who teaches what on the <a href="/schedule" class="text-clay underline underline-offset-4">weekly schedule</a>.
    </p>
  </section>

  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
        {instructors.map((i) => (
          <a href={`/instructors/${i.slug}`} class="group block">
            <div class="aspect-[4/5] overflow-hidden rounded-lg border border-line">
              <img src={i.image_url} alt={`${i.name}, ${i.role} at Core & Flow Pilates Studio`} class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]" loading="lazy" />
            </div>
            <h2 class="mt-4 font-display text-lg text-ink group-hover:text-clay">{i.name}</h2>
            <p class="text-sm text-ink-muted">{i.role}</p>
            <p class="mt-2 text-xs uppercase tracking-wide text-clay">{(i.specialties || []).join(' · ')}</p>
          </a>
        ))}
      </div>
      {instructors.length === 0 && (
        <p class="text-ink-muted">Instructor bios are loading — check back shortly.</p>
      )}
    </div>
  </section>

  <section class="border-t border-line bg-ink">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-6 py-16 md:flex-row md:items-center md:justify-between">
      <h2 class="font-display text-2xl text-paper md:text-3xl">Pick an instructor, pick a class.</h2>
      <a href="/book" class="shrink-0 rounded-full bg-clay px-7 py-3.5 text-sm font-medium text-paper transition hover:bg-clay-dark">Book a class</a>
    </div>
  </section>
</Base>
