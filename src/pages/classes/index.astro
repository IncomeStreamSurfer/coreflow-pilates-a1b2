---
import Base from '../../layouts/Base.astro';
import { anonClient } from '../../lib/supabase';

const title = "Pilates Class Types | Core & Flow Studio";
const description = "Explore mat, reformer, prenatal, barre fusion, and private pilates classes at Core & Flow Studio in Austin. Find your perfect fit.";

const sb = anonClient();
let classes: any[] = [];
if (sb) {
  const { data } = await sb
    .from('classes')
    .select('slug, name, short_description, level, duration_minutes, price_cents, currency, capacity, image_url')
    .not('published_at', 'is', null)
    .order('sort_order');
  classes = data ?? [];
}

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Pilates Classes at Core & Flow Studio',
  url: (import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app') + '/classes',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: classes.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: (import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app') + '/classes/' + c.slug,
      name: c.name,
    })),
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: (import.meta.env.PUBLIC_SITE_URL || '') + '/' },
    { '@type': 'ListItem', position: 2, name: 'Classes', item: (import.meta.env.PUBLIC_SITE_URL || '') + '/classes' },
  ],
};

function money(cents: number, currency: string) {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: currency.toUpperCase() }).format(cents / 100);
}
---

<Base title={title} description={description} structuredData={[collectionSchema, breadcrumb]}>
  <section class="mx-auto max-w-6xl px-6 py-16 md:py-24">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-clay">Class types</p>
    <h1 class="mt-3 font-display text-4xl tracking-tight text-ink md:text-5xl">Our pilates classes</h1>
    <p class="mt-5 max-w-2xl leading-relaxed text-ink-muted">
      From your first mat class to advanced reformer work, every session at Core &amp; Flow is capped small so instructors can coach — not just count reps. Not sure where to start? Check the <a href="/schedule" class="text-clay underline underline-offset-4">weekly class schedule</a> to see what's running this week, or head straight to <a href="/book" class="text-clay underline underline-offset-4">book a class</a>.
    </p>
  </section>

  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
      <div class="grid gap-8 md:grid-cols-2">
        {classes.map((c) => (
          <a href={`/classes/${c.slug}`} class="group flex gap-5 rounded-lg border border-line bg-white/40 p-6 transition hover:-translate-y-0.5 hover:shadow-sm">
            <img
              src={c.image_url}
              alt={`${c.name} class at Core & Flow Pilates Studio in Austin`}
              class="h-28 w-28 shrink-0 rounded-md object-cover"
              loading="lazy"
            />
            <div>
              <h2 class="font-display text-xl text-ink group-hover:text-clay">{c.name}</h2>
              <p class="mt-1 text-sm text-ink-muted">{c.short_description}</p>
              <p class="mt-3 text-xs uppercase tracking-wide text-ink-muted">
                {c.level} · {c.duration_minutes} min · {money(c.price_cents, c.currency)}
              </p>
            </div>
          </a>
        ))}
      </div>
      {classes.length === 0 && (
        <p class="text-ink-muted">Class listings are loading — check back shortly, or view the <a href="/schedule" class="text-clay underline">full schedule</a>.</p>
      )}
    </div>
  </section>

  <section class="border-t border-line bg-ink">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-6 py-16 md:flex-row md:items-center md:justify-between">
      <h2 class="font-display text-2xl text-paper md:text-3xl">Ready to try a class?</h2>
      <a href="/book" class="shrink-0 rounded-full bg-clay px-7 py-3.5 text-sm font-medium text-paper transition hover:bg-clay-dark">Book a class</a>
    </div>
  </section>
</Base>
