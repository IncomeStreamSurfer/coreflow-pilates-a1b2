---
import Base from '../../layouts/Base.astro';
import { anonClient } from '../../lib/supabase';

const title = "Barre Fusion Pilates Austin | Core & Flow Studio";
const description = "Sculpt and tone with our high-energy barre fusion pilates classes in Austin. Reserve your spot online today.";
const SITE = import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app';

const sb = anonClient();
let cls: any = null;
if (sb) {
  const { data } = await sb.from('classes').select('*').eq('slug', 'barre-fusion').maybeSingle();
  cls = data;
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Barre Fusion Classes',
  description,
  provider: { '@type': 'LocalBusiness', name: 'Core & Flow Pilates Studio' },
  areaServed: { '@type': 'City', name: 'Austin' },
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'Classes', item: SITE + '/classes' },
    { '@type': 'ListItem', position: 3, name: 'Barre Fusion', item: SITE + '/classes/barre-fusion' },
  ],
};

function money(cents?: number, currency = 'usd') {
  if (!cents) return '';
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: currency.toUpperCase() }).format(cents / 100);
}
---

<Base title={title} description={description} structuredData={[serviceSchema, breadcrumb]}>
  <article class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-clay">Barre fusion</p>
    <h1 class="mt-3 font-display text-4xl tracking-tight text-ink md:text-5xl">Barre fusion classes</h1>
    <p class="mt-6 text-lg leading-relaxed text-ink-muted">
      Our <strong>barre fusion classes in Austin</strong> blend ballet-inspired isometric holds with pilates breathwork and control — the highest-energy 45 minutes on our schedule.
    </p>

    <div class="prose prose-lg mt-8 max-w-none leading-relaxed text-ink">
      <p>
        Devon spent a decade as a professional ballet dancer before pilates, and it shows in how this class is built: small pulses at the barre, held plié work, and pilates-style core sequencing between sets so your midline is working the entire time, not just during "ab tracks."
      </p>
      <h2>Who it's for</h2>
      <p>
        Clients who want more cardio-adjacent burn without switching to high-impact training, or mat regulars looking to add variety. No dance background required — the barre is for balance, not choreography.
      </p>
      <h2>What a class looks like</h2>
      <p>
        45 minutes, capped at 12. Expect small isometric pulses at the ballet barre for glutes and thighs, light hand weights for arms, and pilates mat segments woven throughout for core and stretch. Evening slots run most weekdays.
      </p>
      <h2>What you'll notice</h2>
      <p>
        Members describe it as the class that makes their legs shake in the best way — expect deep fatigue in glutes and outer thighs by the last ten minutes. Pair it with a <a href="/classes/mat-pilates" class="text-clay underline underline-offset-4">mat pilates class</a> earlier in the week for a well-rounded two-day split.
      </p>
    </div>

    <div class="mt-12 rounded-lg border border-line bg-white/50 p-6">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-sm text-ink-muted">Duration</p>
          <p class="font-display text-lg text-ink">{cls?.duration_minutes ?? 45} minutes</p>
        </div>
        <div>
          <p class="text-sm text-ink-muted">Drop-in price</p>
          <p class="font-display text-lg text-ink">{money(cls?.price_cents, cls?.currency) || '$28'}</p>
        </div>
        <div>
          <p class="text-sm text-ink-muted">Class size</p>
          <p class="font-display text-lg text-ink">Up to {cls?.capacity ?? 12}</p>
        </div>
        <a href="/book" class="rounded-full bg-clay px-6 py-3 text-sm font-medium text-paper transition hover:bg-clay-dark">Book barre fusion</a>
      </div>
    </div>

    <p class="mt-10 text-sm text-ink-muted">
      Taught by <a href="/instructors/devon-marsh" class="text-clay underline underline-offset-4">Devon Marsh</a>, our senior mat &amp; barre instructor. See <a href="/pricing" class="text-clay underline underline-offset-4">class packages and pricing</a> or check the <a href="/schedule" class="text-clay underline underline-offset-4">full weekly schedule</a> for open times.
    </p>
  </article>
</Base>
