---
import Base from '../../layouts/Base.astro';
import { anonClient } from '../../lib/supabase';

const title = "Private Pilates Sessions Austin | Core & Flow Studio";
const description = "Get personalized attention with private one-on-one pilates sessions at Core & Flow Studio in Austin. Book your session now.";
const SITE = import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app';

const sb = anonClient();
let cls: any = null;
if (sb) {
  const { data } = await sb.from('classes').select('*').eq('slug', 'private-sessions').maybeSingle();
  cls = data;
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Private Pilates Sessions',
  description,
  provider: { '@type': 'LocalBusiness', name: 'Core & Flow Pilates Studio' },
  areaServed: { '@type': 'City', name: 'Austin' },
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'Classes', item: SITE + '/classes' },
    { '@type': 'ListItem', position: 3, name: 'Private Sessions', item: SITE + '/classes/private-sessions' },
  ],
};

function money(cents?: number, currency = 'usd') {
  if (!cents) return '';
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: currency.toUpperCase() }).format(cents / 100);
}
---

<Base title={title} description={description} structuredData={[serviceSchema, breadcrumb]}>
  <article class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-clay">Private sessions</p>
    <h1 class="mt-3 font-display text-4xl tracking-tight text-ink md:text-5xl">Private pilates sessions</h1>
    <p class="mt-6 text-lg leading-relaxed text-ink-muted">
      Our <strong>private pilates sessions in Austin</strong> are one instructor, one client, one hour — built entirely around a movement assessment instead of a fixed class plan.
    </p>

    <div class="prose prose-lg mt-8 max-w-none leading-relaxed text-ink">
      <p>
        Elliot leads our private program, coordinating closely with local physical therapists for clients recovering from injury or surgery. Every new private client starts with a movement assessment — how you sit, stand, breathe, and load — before any exercise programming begins.
      </p>
      <h2>Who it's for</h2>
      <p>
        Clients rehabbing an injury under a PT's guidance, athletes who want programming tailored to a specific sport, or anyone who prefers one-on-one coaching to a group room. It's also the format we recommend for prenatal or postnatal clients who want more individual attention than the group class allows.
      </p>
      <h2>What a session looks like</h2>
      <p>
        55 minutes, entirely one-on-one, using reformer, mat, or a mix depending on your assessment. Elliot builds a running program file so every session builds on the last — no starting from scratch each visit.
      </p>
      <h2>What you'll notice</h2>
      <p>
        Faster, more targeted progress than group classes for specific injuries or goals, plus direct access to ask questions mid-exercise. Many private clients graduate into our small-group <a href="/classes/reformer-pilates" class="text-clay underline underline-offset-4">reformer pilates classes</a> once their program stabilizes.
      </p>
    </div>

    <div class="mt-12 rounded-lg border border-line bg-white/50 p-6">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-sm text-ink-muted">Duration</p>
          <p class="font-display text-lg text-ink">{cls?.duration_minutes ?? 55} minutes</p>
        </div>
        <div>
          <p class="text-sm text-ink-muted">Session price</p>
          <p class="font-display text-lg text-ink">{money(cls?.price_cents, cls?.currency) || '$95'}</p>
        </div>
        <div>
          <p class="text-sm text-ink-muted">Format</p>
          <p class="font-display text-lg text-ink">1-on-1</p>
        </div>
        <a href="/book" class="rounded-full bg-clay px-6 py-3 text-sm font-medium text-paper transition hover:bg-clay-dark">Book a private session</a>
      </div>
    </div>

    <p class="mt-10 text-sm text-ink-muted">
      Taught by <a href="/instructors/elliot-cho" class="text-clay underline underline-offset-4">Elliot Cho</a>, our private sessions &amp; rehab lead. Meet the rest of our <a href="/instructors" class="text-clay underline underline-offset-4">certified instructors</a> or see <a href="/pricing" class="text-clay underline underline-offset-4">pricing</a> for all class formats.
    </p>
  </article>
</Base>
