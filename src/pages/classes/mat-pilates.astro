---
import Base from '../../layouts/Base.astro';
import { anonClient } from '../../lib/supabase';

const title = "Mat Pilates Classes Austin | Core & Flow Studio";
const description = "Build core strength and flexibility in our Austin mat pilates classes. Beginner-friendly sessions—book online today.";
const SITE = import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app';

const sb = anonClient();
let cls: any = null;
if (sb) {
  const { data } = await sb.from('classes').select('*').eq('slug', 'mat-pilates').maybeSingle();
  cls = data;
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Mat Pilates Classes',
  description,
  provider: { '@type': 'LocalBusiness', name: 'Core & Flow Pilates Studio' },
  areaServed: { '@type': 'City', name: 'Austin' },
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'Classes', item: SITE + '/classes' },
    { '@type': 'ListItem', position: 3, name: 'Mat Pilates', item: SITE + '/classes/mat-pilates' },
  ],
};

function money(cents?: number, currency = 'usd') {
  if (!cents) return '';
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: currency.toUpperCase() }).format(cents / 100);
}
---

<Base title={title} description={description} structuredData={[serviceSchema, breadcrumb]}>
  <article class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-clay">Mat pilates</p>
    <h1 class="mt-3 font-display text-4xl tracking-tight text-ink md:text-5xl">Mat pilates classes</h1>
    <p class="mt-6 text-lg leading-relaxed text-ink-muted">
      Our <strong>mat pilates classes in Austin</strong> are where most Core &amp; Flow members start — and where plenty of longtime clients still return every week. No machines, no springs, just your body weight, a mat, and fifty minutes of controlled, deliberate movement.
    </p>

    <div class="prose prose-lg mt-8 max-w-none leading-relaxed text-ink">
      <p>
        Mat work is the original pilates: the sequence Joseph Pilates designed in the 1920s, refined over a century into the version we teach today. Class opens with breathwork and spinal articulation, moves through the classical series — the hundred, roll-up, single-leg circles, saw — and closes with stretching that leaves your whole posterior chain looser than when you walked in.
      </p>
      <h2>Who it's for</h2>
      <p>
        Genuinely all levels. First-timers get modifications for every exercise; regulars get the option to add resistance bands or a magic circle for extra burn. Classes are capped at 12 people, small enough that Devon corrects your form without singling you out in front of the room.
      </p>
      <h2>What a class looks like</h2>
      <p>
        50 minutes, 6:00am and 10:15am weekday slots plus a Saturday morning class. Expect core-focused sequencing — deep transverse abdominis work, pelvic stability, and the kind of controlled breathing that makes the rest of your workouts feel easier. Bring grip socks; mats are provided.
      </p>
      <h2>What you'll notice</h2>
      <p>
        Most members feel looser after their first class and stronger through the midline within four to six weeks of showing up twice a week. It's the class we recommend pairing with <a href="/classes/reformer-pilates" class="text-clay underline underline-offset-4">reformer pilates</a> if you want a two-day-a-week rhythm — mat builds the control, reformer adds resistance.
      </p>
    </div>

    <div class="mt-12 rounded-lg border border-line bg-white/50 p-6">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-sm text-ink-muted">Duration</p>
          <p class="font-display text-lg text-ink">{cls?.duration_minutes ?? 50} minutes</p>
        </div>
        <div>
          <p class="text-sm text-ink-muted">Drop-in price</p>
          <p class="font-display text-lg text-ink">{money(cls?.price_cents, cls?.currency) || '$28'}</p>
        </div>
        <div>
          <p class="text-sm text-ink-muted">Class size</p>
          <p class="font-display text-lg text-ink">Up to {cls?.capacity ?? 12}</p>
        </div>
        <a href="/book" class="rounded-full bg-clay px-6 py-3 text-sm font-medium text-paper transition hover:bg-clay-dark">Book mat pilates</a>
      </div>
    </div>

    <p class="mt-10 text-sm text-ink-muted">
      Taught by <a href="/instructors/devon-marsh" class="text-clay underline underline-offset-4">Devon Marsh</a>, our senior mat &amp; barre instructor. See <a href="/pricing" class="text-clay underline underline-offset-4">class packages and pricing</a> or check the <a href="/schedule" class="text-clay underline underline-offset-4">full weekly schedule</a> for open times.
    </p>
  </article>
</Base>
