---
import Base from '../layouts/Base.astro';
import { anonClient } from '../lib/supabase';

const SITE = import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app';
const sb = anonClient();
let page: any = null;
if (sb) {
  const { data } = await sb.from('pages').select('title, meta_title, meta_description').eq('slug', 'contact').not('published_at', 'is', null).maybeSingle();
  page = data;
}

const title = page?.meta_title || 'Contact Us | Core & Flow Pilates Studio Austin';
const description = page?.meta_description || 'Get in touch with Core & Flow Pilates Studio in Austin.';
const renderedAt = Date.now();

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: SITE + '/contact' },
  ],
};
---

<Base title={title} description={description} structuredData={breadcrumb}>
  <section class="mx-auto grid max-w-5xl gap-12 px-6 py-16 md:grid-cols-2 md:py-24">
    <div>
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-clay">Get in touch</p>
      <h1 class="mt-3 font-display text-4xl tracking-tight text-ink">{page?.title || 'Contact us'}</h1>
      <p class="mt-5 leading-relaxed text-ink-muted">
        Questions about a class, a package, or your first visit? Send a message below — we reply within one business day. Ready to reserve a spot? Head to <a href="/book" class="text-clay underline underline-offset-4">book a class</a> instead.
      </p>
      <div class="mt-8 space-y-2 text-sm text-ink-muted">
        <p><strong class="text-ink">Studio:</strong> 1108 South Congress Ave, Austin, TX 78704</p>
        <p><strong class="text-ink">Phone:</strong> <a href="tel:+15125550142" class="hover:text-clay">(512) 555-0142</a></p>
        <p><strong class="text-ink">Email:</strong> <a href="mailto:hello@coreflowpilates.com" class="hover:text-clay">hello@coreflowpilates.com</a></p>
        <a
          href="https://www.google.com/maps/search/?api=1&query=1108+South+Congress+Ave+Austin+TX+78704"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block pt-2 text-clay underline underline-offset-4"
        >Get directions on Google Maps</a>
      </div>
    </div>

    <form id="contact-form" method="POST" action="/api/contact" class="space-y-4 rounded-lg border border-line bg-white/40 p-6">
      <input type="hidden" name="renderedAt" value={renderedAt} />
      <input type="text" name="website" aria-hidden="true" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0" />

      <div>
        <label for="name" class="text-sm font-medium text-ink">Name</label>
        <input id="name" name="name" type="text" required class="mt-1 w-full rounded-md border border-line bg-paper px-4 py-2.5 text-sm outline-none focus:border-clay" />
      </div>
      <div>
        <label for="email" class="text-sm font-medium text-ink">Email</label>
        <input id="email" name="email" type="email" required class="mt-1 w-full rounded-md border border-line bg-paper px-4 py-2.5 text-sm outline-none focus:border-clay" />
      </div>
      <div>
        <label for="message" class="text-sm font-medium text-ink">Message</label>
        <textarea id="message" name="message" rows="4" required minlength="10" class="mt-1 w-full rounded-md border border-line bg-paper px-4 py-2.5 text-sm outline-none focus:border-clay"></textarea>
      </div>
      <button type="submit" class="w-full rounded-full bg-clay px-6 py-3 text-sm font-medium text-paper transition hover:bg-clay-dark">Send message</button>
      <p id="contact-status" class="text-sm text-ink-muted" role="status"></p>
    </form>
  </section>
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-status');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (status) status.textContent = 'Sending…';
    const body = Object.fromEntries(new FormData(form).entries());
    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const json = await res.json();
      if (res.ok && json.ok) {
        if (status) status.textContent = "Thanks — we'll be in touch within one business day.";
        form.reset();
      } else {
        if (status) status.textContent = json.error || 'Something went wrong — please try again.';
      }
    } catch {
      if (status) status.textContent = 'Network error — please try again.';
    }
  });
</script>
