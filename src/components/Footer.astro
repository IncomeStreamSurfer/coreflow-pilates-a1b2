---
const year = new Date().getFullYear();
---
<footer class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <p class="font-display text-lg">Core &amp; Flow <span class="text-clay">Pilates</span></p>
        <p class="mt-3 max-w-sm text-sm text-ink-muted">
          A boutique pilates studio in Austin, TX offering mat, reformer, and prenatal classes led by certified instructors.
        </p>
        <p class="mt-4 text-sm text-ink-muted">
          1108 South Congress Ave, Austin, TX 78704<br />
          <a href="tel:+15125550142" class="hover:text-ink">(512) 555-0142</a> ·
          <a href="mailto:hello@coreflowpilates.com" class="hover:text-ink">hello@coreflowpilates.com</a>
        </p>
      </div>
      <div>
        <p class="text-sm font-medium text-ink">Studio</p>
        <ul class="mt-3 space-y-2 text-sm text-ink-muted">
          <li><a href="/classes" class="hover:text-ink">Classes</a></li>
          <li><a href="/schedule" class="hover:text-ink">Schedule</a></li>
          <li><a href="/instructors" class="hover:text-ink">Instructors</a></li>
          <li><a href="/pricing" class="hover:text-ink">Pricing</a></li>
        </ul>
      </div>
      <div>
        <p class="text-sm font-medium text-ink">More</p>
        <ul class="mt-3 space-y-2 text-sm text-ink-muted">
          <li><a href="/testimonials" class="hover:text-ink">Testimonials</a></li>
          <li><a href="/about" class="hover:text-ink">About</a></li>
          <li><a href="/contact" class="hover:text-ink">Contact</a></li>
          <li><a href="/book" class="hover:text-ink">Book a class</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-12 flex flex-col gap-2 border-t border-line pt-6 text-xs text-ink-muted md:flex-row md:items-center md:justify-between">
      <p>&copy; {year} Core &amp; Flow Pilates Studio. All rights reserved.</p>
      <p>Austin, Texas</p>
    </div>
  </div>
</footer>
