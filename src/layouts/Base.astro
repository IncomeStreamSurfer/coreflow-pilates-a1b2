---
import SEOHead from '../components/SEOHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  structuredData?: object | object[];
  noindex?: boolean;
}

const { title, description, ogImage, structuredData, noindex } = Astro.props;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Core & Flow Pilates Studio',
  url: import.meta.env.PUBLIC_SITE_URL || 'https://coreflow-pilates.vercel.app',
  telephone: '+1-512-555-0142',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '1108 South Congress Ave',
    addressLocality: 'Austin',
    addressRegion: 'TX',
    postalCode: '78704',
    addressCountry: 'US',
  },
  areaServed: 'Austin, TX',
  priceRange: '$$',
};

const schemas = Array.isArray(structuredData)
  ? [...structuredData, localBusinessSchema]
  : structuredData
    ? [structuredData, localBusinessSchema]
    : [localBusinessSchema];
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} ogImage={ogImage} structuredData={schemas} noindex={noindex} />
  </head>
  <body class="font-body antialiased">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
